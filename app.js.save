const express = require('express');
const os = require('os');

const app = express();
const PORT = 3000;

// Tasks in-memory (بدون MongoDB دلوقتي)
const tasks = [
  { id: 1, name: 'Milk',          status: 'done' },
  { id: 2, name: 'Eggs',          status: 'done' },
  { id: 3, name: 'Bread',         status: 'pending' },
  { id: 4, name: 'Butter',        status: 'pending' },
  { id: 5, name: 'Orange juice',  status: 'pending' },
  { id: 6, name: 'Tea',           status: 'pending' }, // مثال جديد
  { id: 7, name: 'Coffee',        status: 'pending' }  // عنصر جديد مع فاصلة
];

// Route 1: basic info
app.get('/', (req, res) => {
  res.json({
    app:  'CISC 886 Lab 8',
    mode: process.env.MODE || 'local',
    node: process.version,
    host: os.hostname(),
  });
});

// Route 2: tasks grouped by status
app.get('/tasks', (req, res) => {
  // Node 18 لا يدعم Object.groupBy → استخدمنا reduce
  const grouped = tasks.reduce((acc, task) => {
    (acc[task.status] = acc[task.status] || []).push(task);
    return acc;
  }, {});
  res.json(grouped);
});

// Start server
app.listen(PORT, () => {
  console.log('--------------------------------------------------');
  console.log(`  CISC 886 Lab 8 — App started`);
  console.log(`  Port:  ${PORT}`);
  console.log(`  Mode:  ${process.env.MODE || 'local'}`);
  console.log(`  Node:  ${process.version}`);
});
